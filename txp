#!/usr/bin/env zsh

# txp - Live text manipulation preview
#
# Interactive tool for previewing text manipulation commands (tr, sed, awk
# jq, etc.) against input text. Type a command and see live output.
#
# Usage: txp [OPTIONS] [file]
#        command | txp
#
# Options:
#   -s, --sample NAME   use built-in sample: json, TODO other
#   -h, --help          Show this help
#
# Keybindings:
#   Type       Live preview updates
#   Enter      Print output to stdout, command to stderr
#   Ctrl-D     Show man page for current command
#   Ctrl-Y     Copy output to clipboard
#   Ctrl-R     Toggle preview position (right / bottom)
#   Esc        Quit without output
#
# Examples:
#   txp                     # default sample text
#   txp data.txt            # use file as input
#   echo "a:b:c" | txp      # use stdin
#   txp -s json             # JSON sample data
#
# Dependencies: fzf

setopt err_exit no_unset pipe_fail

SCRIPT_DIR=${0:A:h}

sample_name=""
input_file=""

while (( $# )); do
    case $1 in
    -s|--sample) sample_name=$2; shift 2 ;;
    -h|--help)   head -n 30 $0 | tail -n +2 | sed -E 's/^# ?//'; exit 0 ;;
    *)           input_file=$1; shift ;;
    esac
done

# --- Sample data ---

sample_json() {
    cat <<'SAMPLE'
{"id": 101, "user": "alice", "meta": {"ip": "192.168.1.5", "role": "admin"}, "tags": ["prod", "web"], "latency": 45}
{"id": 102, "user": "bob",   "meta": {"ip": "192.168.1.12", "role": "dev"},  "tags": ["test"], "latency": 120}
{"id": 103, "user": "charlie", "meta": {"ip": "10.0.0.42", "role": "ops"},   "tags": ["prod", "db"], "latency": 88}
SAMPLE
}

sample_csv() {
    cat <<'SAMPLE'
id,username,department,salary,join_date
1,jdoe,Engineering,95000,2021-03-15
2,asmith,Sales,82000,2022-11-01
3,rlee,Marketing,78000,2023-01-10
4,bwayne,Engineering,115000,2020-05-22
SAMPLE
}

sample_log() {
    cat <<'SAMPLE'
2023-10-27 10:15:01 INFO [auth] User 'alice' logged in from 192.168.1.5
2023-10-27 10:15:42 WARN [db] Connection pool reaching capacity (90%)
2023-10-27 10:16:12 ERROR [api] 500 Internal Server Error at /v1/upload
2023-10-27 10:17:05 INFO [auth] User 'bob' logout
SAMPLE
}

sample_path() {
    cat <<'SAMPLE'
/usr/local/bin/python3
/etc/nginx/sites-available/default
/home/user/documents/reports/annual_2023.pdf
/var/log/syslog
SAMPLE
}

sample_kv() {
    cat <<'SAMPLE'
user=alice status=active shell=/bin/zsh uid=1001
user=bob status=inactive shell=/bin/bash uid=1002
user=charlie status=active shell=/bin/sh uid=1003
SAMPLE
}

default_sample() {
    print "=== TEXT ==="
    print "The quick brown fox jumps over the lazy dog."
    print "Lorem ipsum dolor sit amet, consectetur adipiscing elit."
    print "\n=== CSV ==="
    sample_csv
    print "\n=== LOG ==="
    sample_log
    print "\n=== PATHS ==="
    sample_path
    print "\n=== KEY-VALUE ==="
    sample_kv
    print "\n=== JSON ==="
    sample_json
}

# --- Resolve input ---

TMPFILE=$(mktemp "${TMPDIR:-/tmp}/txp.XXXXXX")
trap 'rm -f $TMPFILE' EXIT

if [[ -n $sample_name ]]; then
    case $sample_name in
        json) sample_json > $TMPFILE ;;
        csv)  sample_csv > $TMPFILE ;;
        log)  sample_log > $TMPFILE ;;
        path) sample_path > $TMPFILE ;;
        kv)   sample_kv > $TMPFILE ;;
        *)
            print -u2 "Unknown sample: $sample_name"
            print -u2 "Available: json, csv, log, path, kv"
            exit 1
            ;;
    esac
elif [[ -n $input_file ]]; then
    if [[ ! -f $input_file ]];  then
        print -u2 "File not found: $input_file"
        exit 1
    fi
    cp $input_file $TMPFILE
elif [[ ! -t 0 ]]; then
    cat > $TMPFILE
else
    default_sample > $TMPFILE
fi

# --- Launch fzf ---

HEADER="  Ctrl-D: docs   Ctrl-Y: copy   Ctrl-R: toggle layout"
if [[ -n ${TXP_HEADER:-} ]]; then
    HEADER="$TXP_HEADER
$HEADER"
fi

result=$(cat $TMPFILE | fzf \
    --disabled \
    --print-query \
    --query "" \
    --prompt 'cmd> ' \
    --header $HEADER \
    --header-first \
    --layout reverse \
    --preview "$SCRIPT_DIR/txp-exec $TMPFILE {q}" \
    --preview-window 'right,50%,border-left,wrap' \
    --preview-label ' OUTPUT ' \
    --border-label "${TXP_BORDER_LABEL:- INPUT }" \
    --bind "change:transform-header:$SCRIPT_DIR/txp-header {q}" \
    --bind "ctrl-d:preview($SCRIPT_DIR/txp-docs {q})" \
    --bind "ctrl-y:execute-silent($SCRIPT_DIR/txp-exec $TMPFILE {q} | pbcopy)" \
    --bind 'ctrl-r:change-preview-window(down,50%,border-top,wrap|right,50%,border-left,wrap)' \
    --no-sort \
) || exit 0

# First line of output is the query  (the command typed)
cmd=${result%%$'\n'*}

if [[ -n $cmd ]]; then
    print -u2 "# $cmd"
    $SCRIPT_DIR/txp-exec $TMPFILE $cmd
fi
